{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "create-user-command",
  "title": "CreateUserCommand",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email of the user to create"
    },
    "name": {
      "type": "string",
      "description": "Name of the user to create"
    }
  },
  "required": [
    "email",
    "name"
  ],
  "additionalProperties": false
}
